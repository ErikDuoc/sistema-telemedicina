# Archivo de configuración para PRODUCCIÓN
# Copiar a: .env o configurar en el servidor de aplicaciones

# ============================================
# CONFIGURACIÓN SEGURA PARA PRODUCCIÓN
# ============================================

# JWT - CAMBIAR TODOS ESTOS VALORES EN PRODUCCIÓN
JWT_SECRET=your-super-secure-random-secret-key-min-32-chars-change-immediately-in-prod-12345
JWT_EXPIRATION=86400000

# CORS - Especificar EXACTAMENTE tus dominios
CORS_ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com,https://app.tudominio.com

# DATABASE - MySQL/PostgreSQL en producción
# Patient Service DB
DB_URL=jdbc:mysql://db-host:3306/db_patients_prod
DB_USER=patient_user
DB_PASSWORD=secure-password-change-this

# Audit Service DB
AUDIT_DB_URL=jdbc:mysql://db-host:3306/db_audit_prod
AUDIT_DB_USER=audit_user
AUDIT_DB_PASSWORD=secure-password-change-this

# LOGGING
LOG_LEVEL=INFO
LOG_OUTPUT_PATH=/var/log/telemedicina/

# EMAIL (para notificaciones)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@tudominio.com
MAIL_PASSWORD=app-specific-password

# ENCRYPTION
ENCRYPTION_KEY=your-encryption-key-32-chars-minimum-change-in-prod

# SERVICE DISCOVERY (si usas Eureka, Consul, etc)
EUREKA_SERVER=eureka-server:8761

# MONITORING
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================
# NOTA IMPORTANTE
# ============================================
# NUNCA comitear este archivo con valores reales en git
# Usar secretos del CI/CD o gestor de secretos (Vault, AWS Secrets, etc)
# Verificar permisos de archivo: chmod 600 .env

