# Archivo de configuración para DESARROLLO
# Copiar a: .env.local o usarlocalmente

# ============================================
# CONFIGURACIÓN PARA DESARROLLO LOCAL
# ============================================

# JWT - Valor simple de desarrollo (SOLO para desarrollo)
JWT_SECRET=dev-secret-key-this-is-not-secure-change-in-production-12345678
JWT_EXPIRATION=86400000

# CORS - Localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:8080

# DATABASE - H2 o MySQL local
DB_URL=jdbc:h2:mem:telemedicinasdb
DB_USER=sa
DB_PASSWORD=

# LOGGING
LOG_LEVEL=DEBUG
LOG_OUTPUT_PATH=./logs/

# EMAIL (fake en desarrollo)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=dev
MAIL_PASSWORD=dev

# MONITORING
PROMETHEUS_ENABLED=false

# ============================================
# PARA USAR CON DOCKER COMPOSE LOCAL
# ============================================
# DB_URL=jdbc:mysql://mysql:3306/dev_db
# DB_USER=root
# DB_PASSWORD=root

# Este archivo NO debe ser cometido con valores reales
# Es solo una plantilla de referencia

